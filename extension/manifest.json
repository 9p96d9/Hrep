{
  "manifest_version": 3,
  "name": "HrepNext Hand Capture",
  "version": "0.1.0",
  "description": "T4ポーカーサイトのハンドを傍受し、HrepNextサーバーへ送って判断品質を解析する。",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*.tenfourpoker.com/*",
    "https://tenfourpoker.com/*",
    "https://*.tenfour-poker.com/*",
    "https://tenfour-poker.com/*",
    "https://*.t4poker.com/*",
    "https://t4poker.com/*",
    "https://hrep.app/*",
    "https://*.run.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.tenfourpoker.com/*",
        "https://tenfourpoker.com/*",
        "https://*.tenfour-poker.com/*",
        "https://tenfour-poker.com/*",
        "https://*.t4poker.com/*",
        "https://t4poker.com/*"
      ],
      "js": ["interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://*.tenfourpoker.com/*",
        "https://tenfourpoker.com/*",
        "https://*.tenfour-poker.com/*",
        "https://tenfour-poker.com/*",
        "https://*.t4poker.com/*",
        "https://t4poker.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "HrepNext Hand Capture"
  }
}
